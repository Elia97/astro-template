---
import Reveal from '@/components/reveal.astro'
import MainLayout from '@/layouts/main.astro'
import { SITE } from '@/lib/site'

export const prerender = true
---

<MainLayout title={SITE.name} description={SITE.description}>
  {/* Placeholder hero: replaced by the homepage-sections pattern */}
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <Reveal>
      <h1 class="text-4xl font-semibold tracking-tight text-foreground">{SITE.name}</h1>
      <p class="mt-4 max-w-prose text-lg text-muted-foreground">{SITE.description}</p>
    </Reveal>
  </section>
</MainLayout>
