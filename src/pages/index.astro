---
import Hero from '@/components/home/hero.astro'
import MainLayout from '@/layouts/main.astro'
import { getHomepageSections } from '@/lib/homepage'
import { SITE } from '@/lib/site'
// @gen:home-imports (generators insert new imports ABOVE this line)

export const prerender = true

const content = await getHomepageSections(Astro.currentLocale)
---

<MainLayout title={SITE.name} description={SITE.description}>
  <Hero {...content.hero} />
  {/* @gen:home-sections */}
</MainLayout>
