---
import ContactForm from '@/components/contact/contact-form.astro'
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'

import MainLayout from '@/layouts/main.astro'

import { buildBreadcrumbList } from '@/lib/seo'

import { localizedHref } from '@/i18n/href'
import { useTranslations } from '@/i18n/translate'

export const prerender = true

const locale = Astro.currentLocale
const t = useTranslations(locale)
const title = t('contact.pageTitle')
const description = t('contact.pageDescription')

const breadcrumbList = buildBreadcrumbList([
  { name: t('nav.home'), url: localizedHref(locale, '/') },
  { name: title, url: localizedHref(locale, '/contatti') },
])
---

<MainLayout {title} {description} canonicalPath="/contatti" jsonLd={[breadcrumbList]}>
  <Section>
    <Container>
      <div class="mx-auto max-w-2xl">
        <h1 class="font-display font-semibold text-4xl text-foreground tracking-tight">{title}</h1>
        <p class="mt-3 text-muted-foreground">{description}</p>

        <div class="mt-10">
          <ContactForm />
        </div>
      </div>
    </Container>
  </Section>
</MainLayout>
