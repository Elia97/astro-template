---
import { SEO } from 'astro-seo'
import { Font } from 'astro:assets'
import { PUBLIC_ENABLE_DARK_MODE, PUBLIC_ENABLE_VIEW_TRANSITIONS } from 'astro:env/client'
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  image?: string
  noindex?: boolean
}

const { title, description, image, noindex = false } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site).toString()
const ogImage = image ? new URL(image, Astro.site).toString() : undefined
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      PUBLIC_ENABLE_DARK_MODE && (
        <script
          is:inline
          set:html={`
            const saved = localStorage.getItem('theme')
            const sys = matchMedia('(prefers-color-scheme: dark)').matches
            if (saved === 'dark' || (!saved && sys))
              document.documentElement.classList.add('dark')
          `}
        />
      )
    }
    {PUBLIC_ENABLE_VIEW_TRANSITIONS && <ClientRouter />}
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-serif" />
    <Font cssVariable="--font-mono" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />
    <SEO
      title={title}
      {...description ? { description } : {}}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage ?? '',
        },
        ...(description ? { optional: { description } } : {}),
      }}
      twitter={{
        card: 'summary_large_image',
      }}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
