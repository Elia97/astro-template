---
// Base layout: owns the document shell (lang, theme, SEO head, view
// transitions) and the page chrome (skip-link, header, footer).
import { i18n } from 'astro:config/client'
import { ClientRouter } from 'astro:transitions'

import Head from '@/components/head.astro'
import JsFlag from '@/components/js-flag.astro'
import Footer from '@/components/layout/footer.astro'
import Header from '@/components/layout/header.astro'
import SkipLink from '@/components/layout/skip-link.astro'
import ThemeScript from '@/components/theme-script.astro'

import '@/styles/globals.css'

interface Props {
  title: string
  description?: string
  canonicalPath?: string
  ogImage?: string
  jsonLd?: Record<string, unknown>[]
  // Forwarded to <Header>: sit the header transparent over a page's hero instead
  // of the default sticky chrome; 'light' forces white overlay chrome for a hero
  // band that is dark/colored across both themes.
  heroOverlay?: boolean
  overlayChrome?: 'auto' | 'light'
}

const { title, description, canonicalPath, ogImage, jsonLd, heroOverlay = false, overlayChrome = 'auto' } = Astro.props
const lang = Astro.currentLocale ?? i18n?.defaultLocale ?? 'it'
---

<!doctype html>
{/* scroll-pt-20: anchor jumps land clear of the 64px sticky header */}
<html lang={lang} class="scroll-pt-20">
  <head>
    {/* charset/viewport first: the encoding declaration must sit within the
        first 1024 bytes of the document — the inline theme script would push
        it past. The script only needs to run before first paint. */}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <JsFlag />
    <ThemeScript />
    <Head {title} {description} {canonicalPath} {ogImage} {jsonLd} />
    <ClientRouter />
  </head>
  <body class="flex min-h-svh flex-col">
    <SkipLink />
    <Header heroOverlay={heroOverlay} overlayChrome={overlayChrome} />
    {/* tabindex=-1: the skip-link must move real focus, not just the tab start point */}
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
