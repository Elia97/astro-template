---
import Container from '@/components/ui/container.astro'

import { SITE } from '@/lib/site'

const year = new Date().getFullYear()
---

<footer class="border-t border-border/60 bg-background">
  <Container class="py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <p class="text-lg font-semibold tracking-tight text-foreground">{SITE.name}</p>
        <p class="mt-2 text-sm text-muted-foreground">{SITE.description}</p>
      </div>

      <nav aria-label={SITE.strings.legalNav} class="flex flex-col gap-2">
        <p class="text-sm font-medium text-foreground">{SITE.strings.legalHeading}</p>
        {
          SITE.legal.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-10 border-t border-border/60 pt-6 text-sm text-muted-foreground">
      <p>&copy; {year} {SITE.name}. {SITE.strings.allRightsReserved}</p>
    </div>
  </Container>
</footer>
