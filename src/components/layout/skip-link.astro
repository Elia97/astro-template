---
// A11y skip-link: first focusable element on the page, jumps to the layout's
// <main id="main-content">. Visually hidden until keyboard focus.
import { SITE } from '@/lib/site'
---

<a
  href="#main-content"
  class="sr-only z-100 rounded-md bg-primary text-sm font-medium text-primary-foreground focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:px-4 focus:py-2 focus:ring-2 focus:ring-ring"
>
  {SITE.strings.skipToContent}
</a>
