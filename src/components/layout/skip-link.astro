---
// A11y skip-link: first focusable element on the page, jumps to the layout's
// <main id="main-content">. Visually hidden until keyboard focus.
import { useTranslations } from '@/i18n/translate'

const t = useTranslations(Astro.currentLocale)
---

<a
  href="#main-content"
  class="sr-only z-100 rounded-md bg-primary font-medium text-primary-foreground text-sm focus:not-sr-only focus:absolute focus:inset-s-4 focus:top-4 focus:px-4 focus:py-2 focus:ring-2 focus:ring-ring"
>
  {t('a11y.skipToContent')}
</a>
