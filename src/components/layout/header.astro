---
import Button from '@/components/ui/button.astro'
import Container from '@/components/ui/container.astro'
import ThemeToggle from '@/components/ui/theme-toggle.astro'

import { SITE } from '@/lib/site'

import { localizedHref } from '@/i18n/href'
import { useTranslations } from '@/i18n/translate'

const t = useTranslations(Astro.currentLocale)
const href = (path: string) => localizedHref(Astro.currentLocale, path)
---

<header
  class="sticky top-0 z-50 border-border/60 border-b bg-background/80 backdrop-blur-sm supports-backdrop-filter:bg-background/60"
>
  <Container class="flex h-16 items-center justify-between">
    <a href={href('/')} class="font-semibold text-foreground text-lg tracking-tight">
      {SITE.name}
    </a>

    <nav aria-label={t('a11y.primaryNav')} class="hidden items-center gap-6 md:flex">
      {
        SITE.nav.map((link) => (
          <a href={href(link.href)} class="font-medium text-muted-foreground text-sm transition-colors hover:text-foreground">
            {t(link.key)}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle class="text-muted-foreground hover:text-foreground" />
      <Button as="a" href={href(SITE.cta.href)} size="sm">{t(SITE.cta.key)}</Button>
    </div>
  </Container>
</header>
