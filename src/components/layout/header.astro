---
import Button from '@/components/ui/button.astro'
import Container from '@/components/ui/container.astro'

import { SITE } from '@/lib/site'
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-sm supports-backdrop-filter:bg-background/60"
>
  <Container class="flex h-16 items-center justify-between">
    <a href="/" class="text-lg font-semibold tracking-tight text-foreground">
      {SITE.name}
    </a>

    <nav aria-label={SITE.strings.primaryNav} class="hidden items-center gap-6 md:flex">
      {
        SITE.nav.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <Button
        type="button"
        variant="ghost"
        size="icon-md"
        data-theme-toggle
        aria-label={SITE.strings.toggleTheme}
        aria-pressed="false"
        class="text-muted-foreground hover:text-foreground"
      >
        {/* VS15 forces text presentation: WebKit would otherwise render the emoji sun */}
        <span class="hidden dark:inline" aria-hidden="true">☀&#xFE0E;</span>
        <span class="inline dark:hidden" aria-hidden="true">☾</span>
      </Button>
      <Button as="a" href={SITE.cta.href} size="sm">{SITE.cta.label}</Button>
    </div>
  </Container>
</header>
