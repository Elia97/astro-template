---
// Centralized head: single place for title/meta/canonical/OG/Twitter/JSON-LD.
// The layout (`@/layouts/main.astro`) forwards SEO props here; pages talk to
// the layout, never to this component directly. Thin orchestrator: URL/meta
// resolution is pure (./head-seo.ts), rendering is split per concern
// (./head-{alternates,og,twitter,json-ld}.astro).
import HeadAlternates from './head-alternates.astro'
import HeadJsonLd from './head-json-ld.astro'
import HeadOg from './head-og.astro'
import { resolveHeadSeoMeta } from './head-seo'
import HeadTwitter from './head-twitter.astro'

// `| undefined` is explicit so the layout can forward its own optional props
// under `exactOptionalPropertyTypes`.
interface Props {
  title: string
  description?: string | undefined
  canonicalPath?: string | undefined
  ogImage?: string | undefined
  jsonLd?: Record<string, unknown>[] | undefined
}

const { title, description, canonicalPath, ogImage, jsonLd } = Astro.props

const { canonical, ogImageUrl, currentTag, localeAlternates, defaultHref } = resolveHeadSeoMeta({
  currentLocale: Astro.currentLocale,
  canonicalPath: canonicalPath ?? Astro.url.pathname,
  ogImage,
})
---

{/* charset/viewport live in the layout: they must precede the inline theme script */}
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />

<title>{title}</title>
{description ? <meta name="description" content={description} /> : null}
<link rel="canonical" href={canonical} />
<HeadAlternates localeAlternates={localeAlternates} defaultHref={defaultHref} />

<HeadOg
  title={title}
  description={description}
  canonical={canonical}
  currentTag={currentTag}
  localeAlternates={localeAlternates}
  ogImageUrl={ogImageUrl}
/>

<HeadTwitter title={title} description={description} ogImageUrl={ogImageUrl} />

<HeadJsonLd items={jsonLd} />
