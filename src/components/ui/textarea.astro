---
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@/lib/utils'

type Props = HTMLAttributes<'textarea'>

// `value` must be rendered as element CONTENT: <textarea> has no value
// attribute, spreading it would silently produce an empty field.
const { class: className, value, ...rest } = Astro.props
---

<textarea
  class={cn(
    'flex min-h-20 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-hidden disabled:cursor-not-allowed disabled:opacity-50',
    className,
  )}
  {...rest}>{value != null ? value : <slot />}</textarea>
