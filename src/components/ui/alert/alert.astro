---
// Compositional like shadcn: <Alert><AlertTitle/><AlertDescription/></Alert>,
// one file per part, re-exported by ./index.ts.
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/lib/utils'

export const alertVariants = cva('relative w-full rounded-lg border border-border px-4 py-3 text-sm', {
  variants: {
    variant: {
      default: 'bg-background text-foreground',
      destructive: 'border-destructive/50 text-destructive',
    },
  },
  defaultVariants: { variant: 'default' },
})

interface Props extends HTMLAttributes<'div'>, VariantProps<typeof alertVariants> {}

const { variant, class: className, role = 'alert', ...rest } = Astro.props
---

<div role={role} class={cn(alertVariants({ variant }), className)} {...rest}><slot /></div>
