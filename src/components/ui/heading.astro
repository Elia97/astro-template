---
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/lib/utils'

// Semantic tag decoupled from the visual size: pick `as` for the document
// outline, `size` for the type scale. No color baked in — the caller sets it.
export const headingVariants = cva('text-balance font-display font-medium', {
  variants: {
    size: {
      display: 'text-4xl sm:text-6xl 2xl:text-7xl',
      h1: 'text-4xl sm:text-5xl 2xl:text-6xl',
      h2: 'text-3xl sm:text-4xl 2xl:text-5xl',
      h3: 'text-2xl sm:text-3xl',
    },
  },
  defaultVariants: { size: 'h2' },
})

type Props = VariantProps<typeof headingVariants> & {
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'p'
} & HTMLAttributes<'h2'>

const { as: Tag = 'h2', size, class: className, ...rest } = Astro.props
---

<Tag class={cn(headingVariants({ size }), className)} {...rest}>
  <slot />
</Tag>
