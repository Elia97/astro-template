---
// Layout primitive: Tailwind's `container` (breakpoint-snapped width, so every
// section aligns vertically) extended in globals.css with auto centering and
// the responsive gutter. Don't hand-write `container` or `mx-auto max-w-*` in
// components — always go through this. For the rare narrower block, nest a
// wrapper: <Container><div class="mx-auto max-w-3xl">…</div></Container>
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@/lib/utils'

type Props = HTMLAttributes<'div'>

const { class: className, ...rest } = Astro.props
---

<div class={cn('container', className)} {...rest}><slot /></div>
