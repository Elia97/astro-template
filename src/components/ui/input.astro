---
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@/lib/utils'

type Props = HTMLAttributes<'input'>

const { class: className, ...rest } = Astro.props
---

<input
  class={cn(
    'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-hidden disabled:cursor-not-allowed disabled:opacity-50',
    className,
  )}
  {...rest}
/>
