---
// Groups the control with its hint/error text in a horizontal Field — in the
// default vertical orientation Label + control as direct children is enough.
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@/lib/utils'

type Props = HTMLAttributes<'div'>

const { class: className, ...rest } = Astro.props
---

<div class={cn('flex flex-1 flex-col gap-1.5 leading-snug', className)} {...rest}>
  <slot />
</div>
