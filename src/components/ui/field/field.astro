---
// Form field wrapper: label + control + hints grouped with consistent
// spacing. Compositional like shadcn: <Field><FieldLabel/><FieldContent/>
// </Field>, one file per part, re-exported by ./index.ts.
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/lib/utils'

export const fieldVariants = cva('flex w-full gap-1.5', {
  variants: {
    orientation: {
      vertical: 'flex-col',
      horizontal: 'flex-row items-start gap-3',
    },
  },
  defaultVariants: { orientation: 'vertical' },
})

interface Props extends HTMLAttributes<'div'>, VariantProps<typeof fieldVariants> {}

const { orientation, class: className, ...rest } = Astro.props
---

<div role="group" class={cn(fieldVariants({ orientation }), className)} {...rest}>
  <slot />
</div>
