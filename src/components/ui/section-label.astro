---
import { cn } from '@/lib/utils'

interface Props {
  // `| undefined` explicit (not just `?`): callers forward an optional zod
  // field straight through, and `exactOptionalPropertyTypes` treats the two
  // differently.
  label?: string | undefined
  class?: string | undefined
}

const { label, class: className } = Astro.props
---

{
  label && (
    <p class={cn('flex items-center gap-2 font-medium text-primary text-sm sm:text-lg 2xl:text-xl', className)}>
      <span class="relative flex size-2.5 sm:size-3 2xl:size-4" aria-hidden="true">
        <span class="absolute inline-flex size-full rounded-full bg-primary opacity-60 motion-safe:animate-ping" />
        <span class="relative inline-flex size-full rounded-full bg-primary" />
      </span>
      {label}
    </p>
  )
}
