---
// Compositional like shadcn: one file per part, re-exported by ./index.ts.
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/lib/utils'

export const cardVariants = cva('', {
  variants: {
    variant: {
      default: 'rounded-lg border border-border bg-card text-card-foreground shadow-sm',
      // Structure/spacing only: drops the visual container so the card parts can
      // compose inside another shell (glass, gradient, …).
      bare: '',
    },
  },
  defaultVariants: { variant: 'default' },
})

type Props = HTMLAttributes<'div'> & VariantProps<typeof cardVariants>

const { variant, class: className, ...rest } = Astro.props
---

<div class={cn(cardVariants({ variant }), className)} {...rest}>
  <slot />
</div>
