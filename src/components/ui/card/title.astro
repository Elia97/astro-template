---
import type { HTMLAttributes } from 'astro/types'

import { cn } from '@/lib/utils'

interface Props extends HTMLAttributes<'div'> {
  /** Render as a real heading (`h2`/`h3`…) when the card title belongs in the page outline. */
  as?: 'div' | 'span' | 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'
}

const { as: Tag = 'div', class: className, ...rest } = Astro.props
---

<Tag class={cn('font-semibold tracking-tight', className)} {...rest}><slot /></Tag>
