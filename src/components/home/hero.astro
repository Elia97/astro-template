---
import Button from '@/components/ui/button.astro'
import Container from '@/components/ui/container.astro'
import Heading from '@/components/ui/heading.astro'
import Section from '@/components/ui/section.astro'
import SectionLabel from '@/components/ui/section-label.astro'

import type { HomepageSections } from '@/lib/homepage'

type Props = HomepageSections['hero']

const { eyebrow, title, subtitle, buttons } = Astro.props
---

<Section
  spacing="spacious"
  class="relative min-h-svh overflow-hidden border-b border-border bg-background"
>
  <Container class="text-center">
    <SectionLabel label={eyebrow} class="mb-4 justify-center" />
    <Heading as="h1" size="display" class="tracking-tight text-foreground">
      {title}
    </Heading>
    {
      subtitle && (
        <p class="mx-auto mt-6 max-w-2xl text-lg text-pretty text-muted-foreground">{subtitle}</p>
      )
    }
    {
      buttons.length > 0 && (
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          {buttons.map((button, index) => (
            <Button as="a" href={button.url} variant={index === 0 ? 'default' : 'outline'}>
              {button.label}
            </Button>
          ))}
        </div>
      )
    }
  </Container>
</Section>
