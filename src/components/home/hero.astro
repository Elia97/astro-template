---
import Button from '@/components/ui/button.astro'
import Container from '@/components/ui/container.astro'
import Section from '@/components/ui/section.astro'

import type { HomepageSections } from '@/lib/homepage'

type Props = HomepageSections['hero']

const { eyebrow, title, subtitle, buttons } = Astro.props
---

<Section
  spacing="spacious"
  class="relative min-h-svh overflow-hidden border-b border-border bg-background"
>
  <Container class="text-center">
    {
      eyebrow && (
        <p class="mb-4 text-sm font-medium tracking-wide text-muted-foreground uppercase">
          {eyebrow}
        </p>
      )
    }
    <h1 class="text-4xl font-bold tracking-tight text-balance text-foreground sm:text-6xl">
      {title}
    </h1>
    {
      subtitle && (
        <p class="mx-auto mt-6 max-w-2xl text-lg text-pretty text-muted-foreground">{subtitle}</p>
      )
    }
    {
      buttons.length > 0 && (
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          {buttons.map((button, index) => (
            <Button as="a" href={button.url} variant={index === 0 ? 'default' : 'outline'}>
              {button.label}
            </Button>
          ))}
        </div>
      )
    }
  </Container>
</Section>
