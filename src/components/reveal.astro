---
// Attribute-driven reveal-on-scroll wrapper. No animation library: the setup
// lives in lib/motion/reveal.ts, the transition is pure CSS (initial state
// gated on `html.js` + `prefers-reduced-motion: no-preference`, globals.css).
//
// Static fallback: under `prefers-reduced-motion` the binding is a no-op and,
// without the `js` class on <html>, the CSS initial state never applies →
// content stays visible.
//
// Cascade variant (no wrapper needed): put `data-reveal-stagger` on any
// container and `style="--i: {index}"` on each child — children transition
// in sequence, `--reveal-stagger` overrides the 0.08s step.
interface Props {
  /** Initial vertical offset in px (default 24). */
  y?: number
  /** Transition delay in seconds (default 0). */
  delay?: number
  /** Extra classes on the wrapper. */
  class?: string
}

const { y = 24, delay = 0, class: className } = Astro.props
const style = `--reveal-y: ${String(y)}px; --reveal-delay: ${String(delay)}s;`
---

<div data-reveal class={className} style={style}>
  <slot />
</div>

<script>
  import { bindReveals } from '@/lib/motion/reveal'

  bindReveals()
</script>
