---
import type { HTMLAttributes } from 'astro/types'
import { cva, type VariantProps } from 'class-variance-authority'

import { cn } from '@/lib/utils'

export const {{camelCase name}}Variants = cva('', {
  variants: {
    variant: {
      default: '',
    },
  },
  defaultVariants: { variant: 'default' },
})

interface Props extends HTMLAttributes<'div'>, VariantProps<typeof {{camelCase name}}Variants> {}

const { variant, class: className, ...rest } = Astro.props
---

<div class={cn({{camelCase name}}Variants({ variant }), className)} {...rest}><slot /></div>
