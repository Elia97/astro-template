{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",
      "Bash(git remote -v:*)",
      "Bash(git blame:*)",
      "Bash(git config --get:*)",

      "Bash(pnpm install:*)",
      "Bash(pnpm run ci:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run check:*)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm gen*)",
      "Bash(astro dev:*)",
      "Bash(pnpm exec astro dev:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm why:*)",
      "Bash(node --version)",
      "Bash(pnpm --version)",

      "Bash(gh auth status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh label list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh workflow list:*)",

      "Bash(gh api repos/*/milestones)",
      "Bash(gh api repos/*/milestones -f *)",
      "Bash(gh issue create *)",

      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(curl:*)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git checkout -- :*)",
      "Bash(git commit --amend:*)",
      "Bash(git filter-repo:*)",
      "Bash(git filter-branch:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf *:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf node_modules*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(npm install:*)",
      "Bash(yarn:*)",
      "Bash(bun install:*)",

      "Bash(gh issue close *)",
      "Bash(gh issue delete *)",
      "Bash(gh issue reopen *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": ".claude/scripts/block-destructive.sh" }] }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": ".claude/scripts/format-on-write.sh" }]
      }
    ]
  }
}
