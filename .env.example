# ─────────────────────────────────────────────────────────────────────
# astro-template — configuration
#
# Forka il repository, copia questo file in .env e personalizza per il
# tuo progetto. Tutte le variabili sono opzionali: i valori qui sotto
# sono i default in vigore se la variabile non è settata in .env.
#
# Riferimento completo: docs/astro-stack.md (sezione "Theming via env")
# ─────────────────────────────────────────────────────────────────────


# ── Brand colors ─────────────────────────────────────────────────────
# Qualsiasi valore CSS color valido (hex, rgb, hsl, oklch, ...).
# Consigliato oklch per consistenza percettiva e supporto dark mode.

PUBLIC_BRAND_PRIMARY=oklch(0.65 0.2 250)
PUBLIC_BRAND_ACCENT=oklch(0.7 0.18 30)
PUBLIC_BRAND_NEUTRAL=oklch(0.5 0 0)


# ── Typography ───────────────────────────────────────────────────────
# Per ogni ruolo (heading, body):
#   PROVIDER:  google | fontsource | local
#   NAME:      nome del font accettato dal provider
#              (es. "Inter", "Geist", "Manrope" per google)
#   LOCAL_DIR: usata SOLO con PROVIDER=local
#              path relativo a public/fonts/ (es. "brand-sans")
#              il template cerca al suo interno:
#                Regular.woff2     (400, normal)
#                Italic.woff2      (400, italic)
#                Bold.woff2        (700, normal)
#                BoldItalic.woff2  (700, italic)
#              i file mancanti vengono silenziosamente ignorati.

PUBLIC_FONT_HEADING_PROVIDER=google
PUBLIC_FONT_HEADING_NAME=Inter
PUBLIC_FONT_HEADING_LOCAL_DIR=

PUBLIC_FONT_BODY_PROVIDER=google
PUBLIC_FONT_BODY_NAME=Inter
PUBLIC_FONT_BODY_LOCAL_DIR=


# ── Scales (preset chiusi) ───────────────────────────────────────────
# Ogni scale si applica all'intero set di token corrispondenti.

PUBLIC_SPACING_BASE=normal              # compact | normal | comfortable
PUBLIC_RADIUS_SCALE=medium              # none | small | medium | large
PUBLIC_SHADOW_PRESET=soft               # none | flat | soft | dramatic


# ── Feature flags ────────────────────────────────────────────────────

PUBLIC_ENABLE_DARK_MODE=false           # toggle dark mode (class-based)
PUBLIC_ENABLE_VIEW_TRANSITIONS=true     # animazioni tra route changes
