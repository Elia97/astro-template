# ─────────────────────────────────────────────────────────────────────
# astro-template — configuration
#
# Forka il repository, copia questo file in .env e personalizza per il
# tuo progetto. Tutte le variabili sono opzionali: i valori qui sotto
# sono i default in vigore se la variabile non è settata in .env.
#
# Per personalizzare colori, radius e shadow del tema, modifica
# src/styles/theme.css (token shadcn-style in :root e .dark con valori
# oklch).
#
# Riferimento completo: docs/astro-stack.md (sezione "Theming")
# ─────────────────────────────────────────────────────────────────────


# ── Typography ───────────────────────────────────────────────────────
# Tre ruoli (sans/serif/mono). Per ognuno:
#   PROVIDER:  google | fontsource | local
#   NAME:      nome del font accettato dal provider
#   LOCAL_DIR: usata SOLO con PROVIDER=local — path relativo a
#              src/assets/fonts/ (es. "brand-sans"). Il template cerca:
#                Regular.woff2     (400, normal)
#                Italic.woff2      (400, italic)
#                Bold.woff2        (700, normal)
#                BoldItalic.woff2  (700, italic)
#              i file mancanti vengono silenziosamente ignorati. Astro
#              raccomanda src/assets/ rispetto a public/ per evitare
#              duplicazione nel build output.

PUBLIC_SITE_URL=https://example.com

PUBLIC_FONT_SANS_PROVIDER=google
PUBLIC_FONT_SANS_NAME=Inter
PUBLIC_FONT_SANS_LOCAL_DIR=

PUBLIC_FONT_SERIF_PROVIDER=google
PUBLIC_FONT_SERIF_NAME=Lora
PUBLIC_FONT_SERIF_LOCAL_DIR=

PUBLIC_FONT_MONO_PROVIDER=google
PUBLIC_FONT_MONO_NAME=JetBrains Mono
PUBLIC_FONT_MONO_LOCAL_DIR=


# ── Feature flags ────────────────────────────────────────────────────

PUBLIC_ENABLE_DARK_MODE=true            # attiva script anti-FOUC e classe .dark
PUBLIC_ENABLE_VIEW_TRANSITIONS=true     # animazioni tra route changes
