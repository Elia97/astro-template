# Environment variables — copy to `.env` (gitignored) and fill in the values.
# NEVER commit `.env` or real values. Keep this file the up-to-date list of
# every key the project reads: add new variables here as they land.

# --- Contact form / Brevo ---
# Brevo API key — server-only SECRET. Without it the contact action no-ops in
# dev (the form "succeeds", nothing is sent) and refuses explicitly in
# production instead of silently dropping the lead. Set it in the deploy
# provider's project settings, never in git.
# BREVO_API_KEY=

# Email sender (verify the domain's DKIM/SPF/DMARC before go-live):
# CONTACT_FROM_EMAIL="no-reply@example.com"
# CONTACT_FROM_NAME="<PROJECT_NAME>"

# Where contact notifications land:
# CONTACT_TO_EMAIL="info@example.com"
