{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!!**/dist", "!!**/public", "!!src/assets/**/*.svg", "!!.release-please-manifest.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": { "maxLines": 200 }
        }
      },
      "complexity": {
        "noExcessiveLinesPerFunction": "error"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "options": { "functions": ["cn", "cva"] }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [":PACKAGE_WITH_PROTOCOL:", ":PACKAGE:"],
              ":BLANK_LINE:",
              ["@/components/**"],
              ":BLANK_LINE:",
              ["@/layouts/**"],
              ":BLANK_LINE:",
              ["@/lib/**"],
              ":BLANK_LINE:",
              ["@/i18n", "@/i18n/**"],
              ":BLANK_LINE:",
              ["@/actions", "@/actions/**"],
              ":BLANK_LINE:",
              ["@/emails/**"],
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ]
}
